# ============================================================
# ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: .env is git-ignored and will NEVER be committed.
# Keep your API keys and server URLs in .env only.
# ============================================================

# Ollama Configuration
# Your Ollama server URL (replace with your server IP and port)
AGENT_OLLAMA_BASE_URL=http://localhost:11434
AGENT_OLLAMA_MODEL=qwen2.5:32b-instruct

# OpenAI Configuration (optional — only needed if you want GPT-4o fallback)
# Get your key from: https://platform.openai.com/api-keys
AGENT_OPENAI_API_KEY=
AGENT_OPENAI_MODEL=gpt-4o

# Groq Configuration (optional — fast inference for open-source models)
# Get your key from: https://console.groq.com/keys
AGENT_GROQ_API_KEY=
AGENT_GROQ_MODEL=llama-3.3-70b-versatile

# Agent Configuration
AGENT_MAX_ITERATIONS=25
AGENT_CONFIDENCE_THRESHOLD=0.6
AGENT_AUTO_CONFIRM=false

# Server Configuration
AGENT_SERVER_HOST=0.0.0.0
AGENT_SERVER_PORT=8000
AGENT_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Logging (console for development, json for production)
AGENT_LOG_LEVEL=INFO
AGENT_LOG_FORMAT=console

# LangSmith Tracing (optional — for monitoring LLM performance)
# Get your key from: https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=agentic_web_extension
