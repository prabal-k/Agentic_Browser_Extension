	observe --> smart_evaluate;
	reason -.-> ask_user_node;
	reason -.-> create_plan;
	reason -.-> decide_action;
	reason -.-> finalize;
	self_critique_action -.-> create_plan;
	self_critique_action -.-> decide_action;
	self_critique_action -.-> finalize;
	self_critique_action -.-> handle_retry;
	self_critique_action -.-> reason;
	self_critique_action -.-> verify_goal;
	smart_evaluate -.-> evaluate;
	smart_evaluate -.-> self_critique_action;
	verify_goal -.-> create_plan;
	verify_goal -.-> finalize;
	finalize --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
